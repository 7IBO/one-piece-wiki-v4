{
  "$schema": "../../../packages/schema-engine/meta-schemas/relation-type.schema.json",
  "id": "adapted-by",
  "schema_version": 1,
  "labels": {
    "en": { "active": "Adapted by", "inverse": "Adapts" },
    "fr": { "active": "Adapté par", "inverse": "Adapte" }
  },
  "valid_from_types": ["manga-chapter", "arc", "saga"],
  "valid_to_types": ["anime-episode", "film"],
