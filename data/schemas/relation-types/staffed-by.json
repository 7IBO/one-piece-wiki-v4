{
  "$schema": "../../../packages/schema-engine/meta-schemas/relation-type.schema.json",
  "id": "staffed-by",
  "schema_version": 1,
  "labels": {
    "en": { "active": "Staffed by", "inverse": "Worked on" },
    "fr": { "active": "Crédité à", "inverse": "A travaillé sur" }
  },
  "valid_from_types": ["anime-episode", "film", "theme-song", "album", "video-game"],
  "valid_to_types": ["person"],
  "qualifiers": [
    { "id": "role", "value_type": "enum", "enum_ref": "person-roles", "required": true },
    { "id": "since", "value_type": "source_ref", "required": false },
    { "id": "note", "value_type": "string", "required": false }
  ],
  "allow_multiple_concurrent": true,
  "inverse_inferred": true,
  "historical": false
}
