{
  "$schema": "../../../packages/schema-engine/meta-schemas/relation-type.schema.json",
  "id": "depicts",
  "schema_version": 1,
  "labels": {
    "en": { "active": "Depicts", "inverse": "Depicted by" },
    "fr": { "active": "Représente", "inverse": "Représenté par" }
  },
  "valid_from_types": ["image"],
  "valid_to_types": [
    "character",
    "devil-fruit",
    "crew",
    "organization",
    "location",
    "technique",
    "weapon",
    "ship",
    "race",
    "title",
    "concept",
    "event",
    "arc",
    "saga",
    "manga-chapter",
    "anime-episode",
    "film"
  ],
  "qualifiers": [
    { "id": "role", "value_type": "enum", "enum_ref": "depiction-roles", "required": false },
    { "id": "since", "value_type": "source_ref", "required": false }
  ],
  "allow_multiple_concurrent": true,
  "inverse_inferred": false,
  "historical": true
}
