  "default_qualifiers": ["since", "source"],
  "allowed_qualifiers": [
    { "id": "issued_by", "value_type": "entity_ref", "required": false }
  ],
  "ui_hint": { "display_format": "currency_short", "input_widget": "number_with_units" }
}
