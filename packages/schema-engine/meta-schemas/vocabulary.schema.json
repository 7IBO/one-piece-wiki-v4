{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "vocabulary schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 60,
      "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
    },
    "schema_version": {
      "type": "integer",
      "exclusiveMinimum": 0
    },
    "universes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 60,
        "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
      }
    },
    "values": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "labels": {
            "type": "object",
            "properties": {
              "en": {
                "type": "string",
                "minLength": 1
              },
              "fr": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "en",
              "fr"
            ],
            "additionalProperties": false
          },
          "description": {
            "type": "object",
            "properties": {
              "en": {
                "type": "string",
                "minLength": 1
              },
              "fr": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "en",
              "fr"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "labels"
        ],
        "additionalProperties": true
      }
    }
  },
  "required": [
    "id",
    "schema_version",
    "values"
  ],
  "additionalProperties": false
}
