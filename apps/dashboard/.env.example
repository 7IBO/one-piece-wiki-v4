# apps/dashboard environment template — committed to git, no secrets.
#
# Copy this file to .env.local (which IS gitignored) and fill in real
# values. Never paste real secrets in chat with Claude Code — the
# transcript is logged. If a secret leaks into chat, revoke it on
# GitHub / Cloudflare immediately and generate a new one.

# ─────────────────────────────────────────────────────────────────────
# Sessions (ADR-017 — stateless signed cookies, no DB)
# ─────────────────────────────────────────────────────────────────────
# HMAC key used to sign the session cookie. Generate with
#   openssl rand -base64 32
# If omitted in development, an ephemeral secret is generated at boot
# — every restart logs everyone out, fine for `bun run dev`. The
# server REFUSES to start in production without this set.
SESSION_SECRET=REPLACE_ME

# Public origin where the dashboard is served. Used to build the
# GitHub OAuth `redirect_uri`. Must match what the user's browser
# loads (Vite dev → http://localhost:4100). The redirect URL
# registered on the GitHub App settings must be
#   <DASHBOARD_PUBLIC_URL>/api/auth/callback/github
DASHBOARD_PUBLIC_URL=http://localhost:4100

# ─────────────────────────────────────────────────────────────────────
# GitHub App
# ─────────────────────────────────────────────────────────────────────

# GitHub App identification — these two values are public IDs, not secrets.
GITHUB_APP_ID=3717633
GITHUB_APP_CLIENT_ID=Iv23lietqTaxVnKQHgt6

# Client secret — SECRET. Generate at
# https://github.com/settings/apps/3717633 → "Generate a new client secret".
# Paste the value here directly in your editor. Do NOT paste it into the
# Claude Code chat input.
GITHUB_APP_CLIENT_SECRET=REPLACE_ME

# Private key — SECRET. Download the .pem from the same App settings
# page and reference its absolute path here (or paste the contents
# inline; both work). Example absolute path form:
#   GITHUB_APP_PRIVATE_KEY_PATH=C:/path/to/onepiece-wiki.2026-05-15.private-key.pem
GITHUB_APP_PRIVATE_KEY_PATH=REPLACE_ME

# Webhook secret — SECRET. Set this in the GitHub App settings under
# "Webhook secret" and copy the same value here.
GITHUB_APP_WEBHOOK_SECRET=REPLACE_ME

# Comma-separated list of GitHub usernames with ADMIN privileges
# (review + merge + promote images + block contributors).
#
# Phase 4 / 7.0: this is also the auth allow-list — only listed users
# can sign in at all. Phase 7.2 opens auth to any GitHub-authenticated
# user, after which the dashboard treats listed users as 'admin' tier
# and everyone else as 'contributor' tier. See ROADMAP Phase 7 +
# ADR-015.
#
# Comma-separated, no spaces. Default kept as a single login — keep
# the set small until Phase 7 reviewing tooling lands.
ADMIN_GITHUB_USERNAMES=7IBO

# Comma-separated list of GitHub usernames blocked from any write
# operation (login, presign-upload, save). Useful as a fast revoke
# without code changes for authenticated trolls.
BLOCKED_GITHUB_USERNAMES=

# ─────────────────────────────────────────────────────────────────────
# Anonymous contributions (Phase 7.2 — ADR-015 revised)
# ─────────────────────────────────────────────────────────────────────
# The dashboard accepts writes from unauthenticated visitors too.
# These knobs are the only handle on anonymous abuse — leave the
# defaults unless you see abuse, in which case lower the limits or
# add to BLOCKED_IPS.

# Comma-separated IPv4/IPv6 addresses blocked from any write
# operation. Matched against X-Forwarded-For first-hop in deployed
# env or the connecting socket in local dev.
BLOCKED_IPS=

# Per-IP rate limits for unauthenticated traffic. Counted with an
# in-memory token bucket that resets on server restart.
ANON_WRITE_LIMIT_PER_HOUR=10
ANON_UPLOAD_LIMIT_PER_HOUR=20

# Note: anonymous contributors pick their own display name (a plain
# string surfaced verbatim in the PR body, never as a GitHub @handle).
# No IP-derived data is ever stored or surfaced — rate-limiting is the
# only IP usage and it stays in process memory.

# Data repository the dashboard's saves will target (owner/repo form).
DATA_REPO=

# ─────────────────────────────────────────────────────────────────────
# Cloudflare R2 (image storage)
# ─────────────────────────────────────────────────────────────────────
#
# Setup procedure:
#   1. Cloudflare dashboard → R2 → create a bucket.
#   2. R2 → "Manage R2 API Tokens" → "Account API Tokens" tab →
#      Create token, permissions = Object Read & Write, scoped to your
#      bucket only, TTL Forever, Allowed IPs empty.
#   3. Copy the Access Key ID + Secret Access Key + Endpoint shown
#      once after creation into the fields below.
#   4. Enable public access: either R2.dev subdomain (dev) or connect
#      a Cloudflare-DNS custom domain (prod). Copy the resulting URL
#      into R2_PUBLIC_BASE_URL (no trailing slash).
#   5. Add a CORS rule on the bucket that allows your dashboard
#      origin to PUT and GET — see docs/IMAGES.md for the JSON.
#
# The dashboard's API server never sees image bytes — it only mints
# presigned PUT URLs that the browser uploads to directly.

# Account ID — public-ish identifier. Visible in the Cloudflare
# dashboard URL: https://dash.cloudflare.com/<id>/...
R2_ACCOUNT_ID=REPLACE_ME

# S3-compatible Access Key ID issued by R2. ~20 chars.
R2_ACCESS_KEY_ID=REPLACE_ME

# S3-compatible Secret Access Key issued by R2. ~40 chars.
# SECRET. Cloudflare shows it only once at token-creation time.
R2_SECRET_ACCESS_KEY=REPLACE_ME

# Bucket name (e.g. one-piece-wiki-images).
R2_BUCKET=REPLACE_ME

# Public base URL prefix for assets. Either:
#   - the R2.dev subdomain (dev only): https://pub-<hash>.r2.dev
#   - your custom domain via Cloudflare DNS: https://img.example.com
# No trailing slash.
R2_PUBLIC_BASE_URL=REPLACE_ME

# Optional: max upload size in bytes. Defaults to 25 MB.
# R2_MAX_UPLOAD_BYTES=26214400
