# apps/dashboard environment template — committed to git, no secrets.
#
# Copy this file to .env.local (which IS gitignored) and fill in real
# values. Never paste real secrets in chat with Claude Code — the
# transcript is logged. If a secret leaks into chat, revoke it on
# GitHub immediately and generate a new one.

# GitHub App identification — these two values are public IDs, not secrets.
GITHUB_APP_ID=3717633
GITHUB_APP_CLIENT_ID=Iv23lietqTaxVnKQHgt6

# Client secret — SECRET. Generate at
# https://github.com/settings/apps/3717633 → "Generate a new client secret".
# Paste the value here directly in your editor. Do NOT paste it into the
# Claude Code chat input.
GITHUB_APP_CLIENT_SECRET=REPLACE_ME

# Private key — SECRET. Download the .pem from the same App settings
# page and reference its absolute path here (or paste the contents
# inline; both work). Example absolute path form:
#   GITHUB_APP_PRIVATE_KEY_PATH=C:/path/to/onepiece-wiki.2026-05-15.private-key.pem
GITHUB_APP_PRIVATE_KEY_PATH=REPLACE_ME

# Webhook secret — SECRET. Set this in the GitHub App settings under
# "Webhook secret" and copy the same value here.
GITHUB_APP_WEBHOOK_SECRET=REPLACE_ME

# Comma-separated list of GitHub usernames allowed to authenticate.
# Phase 4.2 uses this as the admin allowlist (per ROADMAP Phase 4 Task 1).
ADMIN_GITHUB_USERNAMES=

# Data repository the dashboard's saves will target (owner/repo form).
DATA_REPO=
