# Per-machine Claude Code permissions
.claude/settings.local.json

# Claude Code agent worktrees (created by /agent and similar — each is
# its own git clone, never meant to be tracked by the parent).
.claude/worktrees/

# Dependencies
node_modules/
bun.lockb

# Build artifacts
dist/
build/
.turbo/
# TanStack Start / Nitro build output (apps/dashboard)
.output/
.nitro/
.tanstack/

# Generated schemas
packages/schemas/generated/

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# TypeScript
*.tsbuildinfo

# Coverage
coverage/

# Local temp files for commit message editing
.commit-msg.tmp

# Cached dev session HMAC secret (apps/dashboard/api/session.ts) — see
# ADR-017. Generated on first `bun run dev` so hot-reload doesn't
# invalidate the cookie. Never committed; never used in production.
apps/dashboard/.dev-session-secret
