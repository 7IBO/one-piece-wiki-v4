.commit-msg.tmp

# Cached dev session HMAC secret (apps/dashboard/api/session.ts) — see
# ADR-017. Generated on first `bun run dev` so hot-reload doesn't
# invalidate the cookie. Never committed; never used in production.
apps/dashboard/.dev-session-secret

# TanStack Start auto-generates the route tree from src/routes/.
apps/dashboard/src/routeTree.gen.ts

# TanStack Start build artifacts.
apps/dashboard/.tanstack/

# Vercel Build Output API artifacts (generated by scripts/build-vercel.mjs).
apps/dashboard/.vercel/
