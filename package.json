{
  "name": "one-piece-wiki",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "turbo run typecheck",
    "lint": "oxlint .",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "schema:check": "bun packages/schema-engine/src/cli/check.ts",
    "schema:generate": "bun packages/schema-engine/src/cli/generate.ts",
    "validate": "bun packages/schema-engine/src/cli/validate.ts",
    "check:references": "bun packages/schema-engine/src/cli/check-references.ts",
    "format:data": "bun packages/schema-engine/src/cli/format-data.ts",
    "build:data": "bun packages/db-builder/src/cli/build.ts",
    "dashboard:dev": "bun --filter @onepiece-wiki/dashboard dev",
    "dashboard:build": "bun --filter @onepiece-wiki/dashboard build",
    "dashboard:vercel-build": "bun --filter @onepiece-wiki/dashboard vercel-build",
    "check:frontend-extensions": "bun scripts/check-frontend-extensions.ts",
    "fix:frontend-extensions": "bun scripts/strip-frontend-extensions.ts",
    "setup:r2-cors": "bun scripts/setup-r2-cors.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "3.1048.0",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/bun": "^1.1.13",
    "concurrently": "9.2.1",
    "dprint": "^0.49.0",
    "lefthook": "^1.10.0",
    "oxlint": "^0.15.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
